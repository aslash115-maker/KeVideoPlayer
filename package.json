{
  "name": "video-frame-studio",
  "version": "1.0.0",
  "description": "Electron app: extract every frame from a video, preview, apply 25+ filters, export individually.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "dist": "electron-builder --win portable --x64"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.3.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "build": {
    "appId": "com.aslash115.kevideoplayer",
    "productName": "KeVideoPlayer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "docs/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/ffprobe-static/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-portable.exe"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    }
  }
}
